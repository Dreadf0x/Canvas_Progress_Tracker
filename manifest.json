{
  "manifest_version": 3,
  "name": "Canvas Progress Bar",
  "version": "0.6.1",
  "description": "Canvas module progress tracker with instructor rules, role detection, and collapsible panel.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://ubtech.instructure.com/*"
  ],
    "content_scripts": [
    {
      "matches": [
        "https://ubtech.instructure.com/courses/*/modules*"
      ],
      "js": [
       "content.js"
    ],
      "css": [
        "css/tracker.css"
      ],
      "run_at": "document_idle"
    }
]
}